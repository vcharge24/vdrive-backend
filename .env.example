# Vdrive Platform - Docker Compose Environment Variables
# Copy this file to .env and update values as needed

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_DB=vdrive_users
POSTGRES_USER=vdrive
POSTGRES_PASSWORD=vdrive123
POSTGRES_PORT=5432

# ============================================================================
# Service Ports
# ============================================================================
DISCOVERY_SERVER_PORT=8761
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8082
FRONTEND_PORT=3000

# ============================================================================
# JWT Configuration
# ============================================================================
# IMPORTANT: Change this in production! Use a strong, random secret
JWT_SECRET=vdrive-jwt-secret-key-for-development-only-change-in-production

# ============================================================================
# Spring Boot Configuration
# ============================================================================
# Environment: development, staging, production
NODE_ENV=production

# Database DDL Auto: none, validate, update, create, create-drop
JPA_DDL_AUTO=update

# Logging level: OFF, ERROR, WARN, INFO, DEBUG, TRACE
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_AE_VDRIVE=DEBUG

# ============================================================================
# Email/SMTP Configuration (for Notification Service)
# ============================================================================
# Gmail example: smtp.gmail.com (requires App Password, not regular password)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587

# Gmail address or configured email account
SPRING_MAIL_USERNAME=your-email@gmail.com

# Gmail App Password or SMTP password
SPRING_MAIL_PASSWORD=your-app-specific-password

# ============================================================================
# Optional: Advanced Configuration
# ============================================================================
# Database connection pool settings (User Service)
# SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
# SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5

# Eureka client settings
# EUREKA_CLIENT_REGISTER_WITH_EUREKA=true
# EUREKA_CLIENT_FETCH_REGISTRY=true

# API Gateway rate limiting (if configured)
# SPRING_CLOUD_GATEWAY_ROUTES_RATE_LIMIT_ENABLED=true
# SPRING_CLOUD_GATEWAY_ROUTES_RATE_LIMIT_REQUESTS_PER_SECOND=100
